{
  "name": "peptide-hub-contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network robinhoodTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy-mainnet.ts --network robinhoodMainnet",
    "scrape:glp1": "ts-node scripts/scrape-glp1-prices.ts",
    "scrape:glp1:scouter": "SKIP_BASKET=1 ts-node scripts/scrape-glp1-prices.ts",
    "scrape:glp1:basket": "SKIP_SCOUTER=1 ts-node scripts/scrape-glp1-prices.ts",
    "push:glp1": "hardhat run scripts/push-glp1-prices.ts --network robinhoodTestnet",
    "push:glp1:dry": "DRY_RUN=1 hardhat run scripts/push-glp1-prices.ts --network robinhoodTestnet",
    "deploy:plp": "hardhat run scripts/deploy-plp.ts --network robinhoodTestnet",
    "deploy:usdc-plp": "hardhat run scripts/deploy-usdc-plp.ts --network robinhoodTestnet",
    "seed:history": "ts-node scripts/seed-price-history.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.9",
    "@types/node": "^22.20.1",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "cheerio": "^1.2.0"
  }
}
