NEXT_PUBLIC_ROBINHOOD_RPC_URL=https://rpc.testnet.chain.robinhood.com

# --- Waitlist (Supabase) ---
# Project URL + service role (server) preferred for count + inserts
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: dual-write to Google Sheet via Apps Script / Zapier webhook
GOOGLE_SHEETS_WEBHOOK_URL=

# --- PEPT Oracle B2B API ---
# Demo key (public docs). Production keys via admin API.
ORACLE_API_PUBLIC_DEMO_KEY=pept_demo_public
# Comma-separated bootstrap keys (seeded as Pro)
ORACLE_API_KEYS=
# Require a valid key on every request (recommended for api.pept.trade)
ORACLE_API_REQUIRE_KEY=false
# Admin secret for /api/v1/oracle/admin/*
ORACLE_ADMIN_SECRET=
# HMAC secret for signed price attestations
ORACLE_ATTEST_HMAC_SECRET=
# Optional ECDSA PEM (escaped newlines \\n) for dual-signed attestations
ORACLE_ATTEST_PRIVATE_KEY=
ORACLE_ATTEST_PUBLIC_KEY=

# Upstash Redis (multi-instance rate limits + durable keys/webhooks)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe billing (Pro / Enterprise)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ORACLE_PRO=
STRIPE_PRICE_ORACLE_ENTERPRISE=

# Keeper fanout after price push (contracts push script)
# ORACLE_API_FANOUT_URL=https://pept.trade/api/v1/oracle/admin/fanout
